# Copy to .env.local and fill in from Supabase: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key

# Publieke site-URL (productie). Nodig voor OAuth-redirect na Google-login.
# Lokaal: http://localhost:3000  |  Vercel: https://jouw-app.vercel.app
NEXT_PUBLIC_SITE_URL=

# Docenten zonder bevestigingsmail:
# Supabase → Authentication → Providers → Email → «Confirm email» UIT.

# Google voor docenten (optioneel):
# 1) Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
#    (type: Web application). Authorized redirect URI:
#    https://<PROJECT_REF>.supabase.co/auth/v1/callback  (staat in Supabase bij Google provider)
# 2) Supabase → Authentication → Providers → Google: Client ID + Secret invullen, opslaan.
# 3) URL Configuration → Redirect URLs: http://localhost:3000/teacher en https://jouw-domein/teacher
# 4) Zet hieronder true en herbouw / herdeploy:
NEXT_PUBLIC_TEACHER_GOOGLE_AUTH=false
