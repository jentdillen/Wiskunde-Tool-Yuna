# Copy to .env.local and fill in from Supabase: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key

# Docenten: direct inloggen na registreren (zonder bevestigingsmail)
# Supabase Dashboard → Authentication → Providers → Email → zet "Confirm email" UIT.
# Zet dit AAN als je echte bevestigingsmails wilt; configureer dan Authentication → SMTP (of een mailprovider).
