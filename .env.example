# Copy to .env.local and fill in from Supabase: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key

# Publieke URL van de site (productie). Gebruikt in bevestigingsmails (Supabase emailRedirectTo).
# Lokaal mag je dit weglaten; dan wordt http://localhost:3000 gebruikt.
# Voorbeeld: NEXT_PUBLIC_SITE_URL=https://jouw-app.vercel.app

# Bevestigingsmail voor docenten (Supabase Dashboard):
# - Authentication → Providers → Email → «Confirm email» AAN
# - Authentication → SMTP: vul je mailprovider in (of gebruik Supabase / een dienst zoals Resend)
# - Authentication → URL Configuration:
#   - Site URL = je productie-URL (of http://localhost:3000 voor dev)
#   - Redirect URLs: voeg toe: http://localhost:3000/teacher/login en https://jouw-domein/teacher/login
