# Copy to .env.local and fill in from Supabase: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key

# Publieke site-URL (productie). Nodig voor auth redirect links.
# Lokaal: http://localhost:3000  |  Vercel: https://jouw-app.vercel.app
NEXT_PUBLIC_SITE_URL=

# Docenten met bevestigingsmail:
# Supabase → Authentication → Providers → Email → «Confirm email» AAN.
# SMTP ook instellen (anders komt er vaak geen mail aan):
# Supabase → Authentication → SMTP.
# URL Configuration:
# - Site URL: je echte app-URL
# - Redirect URLs: voeg minstens toe:
#   http://localhost:3000/teacher/email-confirmed
#   https://jouw-domein/teacher/email-confirmed
#   (optioneel ook /teacher/login voor andere flows)
